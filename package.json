  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "build:vercel": "pnpm db:deploy && next build",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy && prisma generate",
